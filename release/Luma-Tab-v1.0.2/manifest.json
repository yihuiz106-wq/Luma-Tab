{
  "manifest_version": 3,
  "name": "Luma Tab",
  "version": "1.0.2",
  "key": "",
  "description": "A calm AI-powered new tab with bookmarks, focus, and lightweight organization.",
  "permissions": ["bookmarks", "storage", "tabs"],
  "host_permissions": ["https://api.deepseek.com/*"],
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  }
}
